---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Clankers Leaderboard">
  <div class="page">
    <div class="bg-glow"></div>

    <header>
      <div class="logo">Clankers Leaderboard</div>
      <nav>
        <a href="https://github.com/UnsafeLabs/Bounty-Hunters" target="_blank">GitHub Repository</a>
      </nav>
    </header>

    <div class="hero-banner">
      <div class="banner-inner">
        <div class="banner-text">
          <h1>Open-Source Bot Blocklist</h1>
          <p>This leaderboard data is freely available as JSON to help protect your open-source projects from automated bot accounts.</p>
        </div>
        <a class="banner-btn" href="https://github.com/UnsafeLabs/Bounty-Hunters/blob/main/clankers.json" target="_blank">Get JSON</a>
      </div>
    </div>

    <main>
      <!-- Podium -->
      <div class="podium-area">
        <div class="podium">
          <!-- 2nd place -->
          <div class="podium-spot" id="podium-2">
            <img class="avatar" alt="" />
            <div class="podium-name">--</div>
            <div class="pedestal p2">
              <div class="trophy">🥈</div>
              <div class="points-label"><span class="points-count">--</span> PRs</div>
            </div>
          </div>

          <!-- 1st place -->
          <div class="podium-spot" id="podium-1">
            <img class="avatar avatar-first" alt="" />
            <div class="podium-name name-first">--</div>
            <div class="pedestal p1">
              <div class="trophy">🏆</div>
              <div class="points-label"><span class="points-count">--</span> PRs</div>
            </div>
          </div>

          <!-- 3rd place -->
          <div class="podium-spot" id="podium-3">
            <img class="avatar" alt="" />
            <div class="podium-name">--</div>
            <div class="pedestal p3">
              <div class="trophy">🥉</div>
              <div class="points-label"><span class="points-count">--</span> PRs</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats banner -->
      <div class="stats-banner" id="stats-banner">
        <span>Tracked <strong id="total-bots">--</strong> fully automated GitHub accounts with <strong id="total-prs">--</strong> total PRs — latest PR sent <strong id="last-updated">--</strong></span>
      </div>

      <!-- Table / Graph -->
      <div class="table-card">
        <div class="table-header">
          <h2>Top Clankers</h2>
          <div class="view-tabs">
            <button class="tab-btn active" data-view="table">Table</button>
            <button class="tab-btn" data-view="graph">Bar</button>
            <button class="tab-btn" data-view="growth">Graph</button>
          </div>
        </div>

        <div id="view-table">
          <table>
            <thead>
              <tr>
                <th style="width:50px">Rank</th>
                <th>Username</th>
                <th style="width:100px;white-space:nowrap">Total PRs</th>
                <th style="width:150px">First PR</th>
                <th style="width:150px">Last PR</th>
                <th style="width:160px;white-space:nowrap">View all PRs</th>
              </tr>
            </thead>
            <tbody id="table-body">
              <tr><td colspan="6" class="loading">Loading data...</td></tr>
            </tbody>
          </table>
          <div class="pagination" id="pagination"></div>
        </div>

        <div id="view-graph" class="view-graph" style="display:none">
          <div class="graph-toolbar" style="justify-content:flex-end">
            <div class="time-filters">
              <button class="filter-btn active" data-range="1">24h</button>
              <button class="filter-btn" data-range="7">7d</button>
              <button class="filter-btn" data-range="30">30d</button>
              <button class="filter-btn" data-range="0">All</button>
            </div>
          </div>
          <div class="chart-wrap">
            <canvas id="pr-chart"></canvas>
          </div>
        </div>

        <div id="view-growth" class="view-graph" style="display:none">
          <div class="graph-toolbar">
            <div class="time-filters">
              <button class="filter-btn growth-metric active" data-metric="bots">Bots</button>
              <button class="filter-btn growth-metric" data-metric="prs">PRs</button>
            </div>
            <div class="time-filters">
              <button class="filter-btn growth-filter active" data-range="1">24h</button>
              <button class="filter-btn growth-filter" data-range="7">7d</button>
              <button class="filter-btn growth-filter" data-range="30">30d</button>
              <button class="filter-btn growth-filter" data-range="0">All</button>
            </div>
          </div>
          <div class="chart-wrap">
            <canvas id="growth-chart"></canvas>
          </div>
        </div>
      </div>
    </main>

    <footer>
      <p>Data from <a href="https://github.com/UnsafeLabs/Bounty-Hunters" target="_blank">UnsafeLabs/Bounty-Hunters</a> &middot; Refreshes every 5 minutes</p>
    </footer>
  </div>
</Layout>

<script>
  const TURSO_URL = 'https://clankers-leaderboard-stacymoon.aws-us-east-2.turso.io/v2/pipeline';
  // Read-only token — safe to expose client-side, can only SELECT, cannot modify data
  const TURSO_TOKEN = 'eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.eyJhIjoicm8iLCJleHAiOjE4MTAyODAwOTAsImlhdCI6MTc3ODc0NDA5MCwiaWQiOiIwMTllMjU2Ni0yNDAxLTdkYjctYTU0Ni0zMzljNTAxNDkxYmYiLCJyaWQiOiIxODUwZjIyMy04NjM1LTRmZTEtYjViMy02NTRhNDM5YTcxNGMifQ.VXSPG4VjZbG8sjycVkU6IAZOunP6h1igJHCzgqorNElVkqczDJEgpYgcIEPTcYcNRV06CKWtcyXFrt0XP90fAQ';

  async function fetchFromTurso(): Promise<Clanker[]> {
    const res = await fetch(TURSO_URL, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${TURSO_TOKEN}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        requests: [
          { type: 'execute', stmt: { sql: 'SELECT username, total_prs, first_pr, last_pr FROM clankers ORDER BY total_prs DESC' } },
          { type: 'close' }
        ]
      })
    });
    const data = await res.json();
    const rows = data.results[0].response.result.rows;
    return rows.map((row: any) => ({
      username: row[0].value,
      total_prs: parseInt(row[0 + 1].value),
      first_pr: row[2].value,
      last_pr: row[3].value,
    }));
  }

  function formatDate(iso: string): string {
    const d = new Date(iso);
    return d.toLocaleString('en-US', {
      month: 'short', day: 'numeric',
      hour: '2-digit', minute: '2-digit', second: '2-digit',
      hour12: false,
    });
  }

  interface Clanker {
    username: string;
    total_prs: number;
    first_pr: string;
    last_pr: string;
  }

  function ghAvatar(username: string): string {
    return `https://wsrv.nl/?url=github.com/${username}.png&w=96&h=96&fit=cover&default=1`;
  }

  function ghProfile(username: string): string {
    return `https://github.com/${username}`;
  }

  function renderPodium(data: Clanker[]) {
    [
      { el: document.getElementById('podium-1')!, i: 0 },
      { el: document.getElementById('podium-2')!, i: 1 },
      { el: document.getElementById('podium-3')!, i: 2 },
    ].forEach(({ el, i }) => {
      const bot = data[i];
      if (!bot) return;
      const img = el.querySelector('.avatar') as HTMLImageElement;
      img.src = ghAvatar(bot.username);
      img.alt = bot.username;
      el.querySelector('.podium-name')!.textContent = bot.username;
      el.querySelector('.points-count')!.textContent = bot.total_prs.toLocaleString();
    });
  }

  let currentPage = 1;
  let tableData: Clanker[] = [];

  function getPageSize(): number {
    return window.innerWidth <= 640 ? 10 : 15;
  }

  function renderTable(data: Clanker[]) {
    tableData = data;
    renderTablePage();
  }

  function renderTablePage() {
    const pageSize = getPageSize();
    const totalPages = Math.ceil(tableData.length / pageSize);
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    const start = (currentPage - 1) * pageSize;
    const page = tableData.slice(start, start + pageSize);

    const tbody = document.getElementById('table-body')!;
    tbody.innerHTML = page.map((bot, i) => {
      const rank = start + i + 1;
      const rankDisplay = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : `#${rank}`;
      return `<tr class="${rank <= 3 ? 'top-row' : ''}">
        <td class="rank">${rankDisplay}</td>
        <td class="username"><a href="${ghProfile(bot.username)}" target="_blank">${bot.username}</a></td>
        <td class="prs">${bot.total_prs.toLocaleString()}</td>
        <td class="date">${formatDate(bot.first_pr)}</td>
        <td class="date">${formatDate(bot.last_pr)}</td>
        <td class="view-prs"><a href="https://github.com/UnsafeLabs/Bounty-Hunters/pulls?q=is%3Apr+author%3A${bot.username}" target="_blank">View on GitHub &#x2197;</a></td>
      </tr>`;
    }).join('');

    renderPagination(totalPages);
  }

  function renderPagination(totalPages: number) {
    const container = document.getElementById('pagination')!;
    if (totalPages <= 1) { container.innerHTML = ''; return; }

    let buttons = '';
    buttons += `<button class="page-btn${currentPage === 1 ? ' disabled' : ''}" data-page="prev">&lsaquo;</button>`;

    const maxVisible = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
    let endPage = Math.min(totalPages, startPage + maxVisible - 1);
    if (endPage - startPage < maxVisible - 1) startPage = Math.max(1, endPage - maxVisible + 1);

    if (startPage > 1) {
      buttons += `<button class="page-btn" data-page="1">1</button>`;
      if (startPage > 2) buttons += `<span class="page-dots">...</span>`;
    }

    for (let p = startPage; p <= endPage; p++) {
      buttons += `<button class="page-btn${p === currentPage ? ' active' : ''}" data-page="${p}">${p}</button>`;
    }

    if (endPage < totalPages) {
      if (endPage < totalPages - 1) buttons += `<span class="page-dots">...</span>`;
      buttons += `<button class="page-btn" data-page="${totalPages}">${totalPages}</button>`;
    }

    buttons += `<button class="page-btn${currentPage === totalPages ? ' disabled' : ''}" data-page="next">&rsaquo;</button>`;

    container.innerHTML = buttons;

    container.querySelectorAll('.page-btn:not(.disabled)').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = (btn as HTMLElement).dataset.page!;
        if (val === 'prev') currentPage--;
        else if (val === 'next') currentPage++;
        else currentPage = parseInt(val);
        renderTablePage();
      });
    });
  }

  function timeAgo(iso: string): string {
    const diff = Date.now() - new Date(iso).getTime();
    const secs = Math.floor(diff / 1000);
    const mins = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);
    if (days > 0) return `${days}d ago`;
    if (hours > 0) return `${hours}h ago`;
    if (mins > 0) return `${mins}m ago`;
    if (secs > 0) return `${secs}s ago`;
    return 'just now';
  }

  let latestPrTime = '';

  function renderStats(data: Clanker[]) {
    const total = data.reduce((s, b) => s + b.total_prs, 0);
    document.getElementById('total-prs')!.textContent = total.toLocaleString();
    document.getElementById('total-bots')!.textContent = data.length.toString();
    const latest = data.reduce((a, b) => (a.last_pr > b.last_pr ? a : b));
    latestPrTime = latest.last_pr;
    document.getElementById('last-updated')!.textContent = timeAgo(latestPrTime);
  }

  setInterval(() => {
    if (latestPrTime) {
      document.getElementById('last-updated')!.textContent = timeAgo(latestPrTime);
    }
  }, 60000);

  async function loadData() {
    try {
      const data = await fetchFromTurso();
      cachedData = data;
      renderPodium(data);
      renderTable(data);
      renderStats(data);
      if (currentView === 'graph') renderChart(data);
      if (currentView === 'growth') renderGrowth(data);
    } catch {
      document.getElementById('table-body')!.innerHTML =
        '<tr><td colspan="6" class="loading">Failed to load data</td></tr>';
    }
  }

  // Tab switching
  let currentView = 'table';
  const allViews = ['table', 'graph', 'growth'];
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const view = (btn as HTMLElement).dataset.view!;
      if (view === currentView) return;
      currentView = view;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      allViews.forEach(v => {
        document.getElementById(`view-${v}`)!.style.display = v === view ? '' : 'none';
      });
      if (cachedData.length) {
        if (view === 'graph') renderChart(cachedData);
        if (view === 'growth') renderGrowth(cachedData);
      }
    });
  });

  // Chart
  let cachedData: Clanker[] = [];
  let chartInstance: any = null;
  let activeRange = 1;

  document.querySelectorAll('#view-graph .filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#view-graph .filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeRange = parseInt((btn as HTMLElement).dataset.range!);
      if (cachedData.length) renderChart(cachedData);
    });
  });

  function filterByRange(data: Clanker[], days: number): Clanker[] {
    if (days === 0) return data;
    const cutoff = new Date(Date.now() - days * 86400000).toISOString();
    return data.filter(b => b.last_pr >= cutoff);
  }

  function renderChart(data: Clanker[]) {
    const filtered = filterByRange(data, activeRange);
    const top = filtered.slice(0, 25);
    const labels = top.map(b => b.username);
    const values = top.map(b => b.total_prs);

    if (chartInstance) chartInstance.destroy();

    const ctx = (document.getElementById('pr-chart') as HTMLCanvasElement).getContext('2d')!;
    chartInstance = new (window as any).Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: 'Total PRs',
          data: values,
          backgroundColor: 'rgba(220, 160, 60, 0.4)',
          borderColor: 'rgba(220, 160, 60, 0.8)',
          borderWidth: 1,
          borderRadius: 4,
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            displayColors: false,
            backgroundColor: 'rgba(30, 18, 8, 0.95)',
            titleColor: '#f0d9b5',
            bodyColor: '#e8c88a',
            borderColor: 'rgba(180, 120, 60, 0.3)',
            borderWidth: 1,
            callbacks: {
              label: (ctx: any) => `${ctx.parsed.x.toLocaleString()} PRs`
            }
          }
        },
        scales: {
          x: {
            grid: { color: 'rgba(180, 120, 60, 0.08)' },
            ticks: { color: '#9a8a75', font: { family: "'SF Mono', 'Fira Code', monospace", size: 11 } },
            title: { display: true, text: 'Total PRs', color: '#9a8a75', font: { family: "'SF Mono', 'Fira Code', monospace", size: 12 } }
          },
          y: {
            grid: { display: false },
            ticks: { color: '#c4b49a', font: { family: "'SF Mono', 'Fira Code', monospace", size: 11 } }
          }
        }
      }
    });
  }

  // Growth chart with Stripe-style projection
  let growthInstance: any = null;
  let growthRange = 1;
  let growthMetric: 'bots' | 'prs' = 'bots';

  document.querySelectorAll('.growth-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.growth-filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      growthRange = parseInt((btn as HTMLElement).dataset.range!);
      if (cachedData.length) renderGrowth(cachedData);
    });
  });

  document.querySelectorAll('.growth-metric').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.growth-metric').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      growthMetric = (btn as HTMLElement).dataset.metric as 'bots' | 'prs';
      if (cachedData.length) renderGrowth(cachedData);
    });
  });

  function renderGrowth(data: Clanker[]) {
    const now = Date.now();
    const isBots = growthMetric === 'bots';
    const sorted = [...data].sort((a, b) => a.first_pr.localeCompare(b.first_pr));

    let allPoints: { x: number; y: number }[];
    if (isBots) {
      allPoints = sorted.map((b, i) => ({ x: new Date(b.first_pr).getTime(), y: i + 1 }));
    } else {
      let cumPrs = 0;
      allPoints = sorted.map(b => {
        cumPrs += b.total_prs;
        return { x: new Date(b.first_pr).getTime(), y: cumPrs };
      });
    }

    let windowStart: number;
    let windowEnd: number;

    if (growthRange > 0) {
      windowStart = now - growthRange * 86400000;
      windowEnd = now + growthRange * 86400000;
    } else {
      windowStart = allPoints.length ? allPoints[0].x : now;
      windowEnd = now;
    }

    const actualPoints = allPoints.filter(p => p.x >= windowStart && p.x <= now);

    const currentValue = allPoints.filter(p => p.x <= now).length > 0
      ? allPoints.filter(p => p.x <= now).slice(-1)[0].y
      : 0;
    if (actualPoints.length && actualPoints[actualPoints.length - 1].x < now) {
      actualPoints.push({ x: now, y: currentValue });
    }

    let projectedPoints: { x: number; y: number }[] = [];
    if (growthRange > 0 && windowEnd > now) {
      const windowData = allPoints.filter(p => p.x >= windowStart && p.x <= now);
      const timeSpan = now - windowStart;
      let rate = 0;
      if (timeSpan > 0 && windowData.length >= 2) {
        const valueGain = windowData[windowData.length - 1].y - windowData[0].y;
        rate = valueGain / timeSpan;
      }

      projectedPoints.push({ x: now, y: currentValue });
      const futureSpan = windowEnd - now;
      const steps = 6;
      for (let i = 1; i <= steps; i++) {
        const t = now + (futureSpan / steps) * i;
        const projected = currentValue + rate * (t - now);
        projectedPoints.push({ x: t, y: Math.round(projected) });
      }
    }

    if (growthInstance) growthInstance.destroy();

    const metricLabel = isBots ? 'Cumulative Bots' : 'Cumulative PRs';
    const metricUnit = isBots ? 'bots' : 'PRs';
    const yTitle = isBots ? 'Total Bots' : 'Total PRs';

    const datasets: any[] = [
      {
        label: metricLabel,
        data: actualPoints,
        borderColor: 'rgba(220, 160, 60, 0.8)',
        backgroundColor: 'rgba(220, 160, 60, 0.1)',
        fill: true,
        borderWidth: 2,
        pointRadius: 0,
        pointHitRadius: 20,
        pointHoverRadius: 6,
        pointBackgroundColor: 'rgba(220, 160, 60, 0.8)',
        pointHoverBackgroundColor: '#e8c88a',
        pointStyle: 'circle',
        tension: 0.3,
      }
    ];

    if (projectedPoints.length > 1) {
      datasets.push({
        label: 'Projected',
        data: projectedPoints,
        borderColor: 'rgba(220, 160, 60, 0.4)',
        backgroundColor: 'rgba(220, 160, 60, 0.03)',
        fill: true,
        borderWidth: 2,
        borderDash: [6, 4],
        pointRadius: 0,
        pointHitRadius: 20,
        pointHoverRadius: 5,
        pointBackgroundColor: 'rgba(220, 160, 60, 0.4)',
        pointHoverBackgroundColor: 'rgba(220, 160, 60, 0.6)',
        pointStyle: 'circle',
        tension: 0.3,
      });
    }

    const nowLinePlugin = {
      id: 'nowLine',
      afterDraw: (chart: any) => {
        if (growthRange === 0) return;
        const xScale = chart.scales.x;
        const yScale = chart.scales.y;
        const xPos = xScale.getPixelForValue(now);
        if (xPos < xScale.left || xPos > xScale.right) return;
        const ctx = chart.ctx;
        ctx.save();
        ctx.beginPath();
        ctx.setLineDash([4, 3]);
        ctx.strokeStyle = 'rgba(180, 120, 60, 0.4)';
        ctx.lineWidth = 1;
        ctx.moveTo(xPos, yScale.top);
        ctx.lineTo(xPos, yScale.bottom);
        ctx.stroke();
        ctx.fillStyle = '#9a8a75';
        ctx.font = "10px 'SF Mono', monospace";
        ctx.textAlign = 'center';
        ctx.fillText('Now', xPos, yScale.top - 6);
        ctx.restore();
      }
    };

    const tickFormat = growthRange === 1
      ? (v: number) => new Date(v).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false })
      : (v: number) => new Date(v).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

    const ctx = (document.getElementById('growth-chart') as HTMLCanvasElement).getContext('2d')!;
    growthInstance = new (window as any).Chart(ctx, {
      type: 'line',
      data: { datasets },
      plugins: [nowLinePlugin],
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'nearest', axis: 'x', intersect: false },
        plugins: {
          legend: { display: projectedPoints.length > 1, position: 'bottom', labels: { color: '#9a8a75', font: { family: "'SF Mono', 'Fira Code', monospace", size: 11 }, usePointStyle: true, pointStyle: 'circle', boxWidth: 8, boxHeight: 8, padding: 15 } },
          tooltip: {
            displayColors: false,
            backgroundColor: 'rgba(30, 18, 8, 0.95)',
            titleColor: '#f0d9b5',
            bodyColor: '#e8c88a',
            borderColor: 'rgba(180, 120, 60, 0.3)',
            borderWidth: 1,
            callbacks: {
              title: (items: any) => {
                const ts = items[0]?.parsed?.x;
                const d = new Date(ts);
                return ts > now ? `${d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} (projected)` : d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
              },
              label: (ctx: any) => `${ctx.parsed.y.toLocaleString()} ${metricUnit}${ctx.datasetIndex === 1 ? ' (est.)' : ''}`
            }
          }
        },
        scales: {
          x: {
            type: 'linear',
            min: windowStart,
            max: growthRange > 0 ? windowEnd : undefined,
            grid: { color: 'rgba(180, 120, 60, 0.08)' },
            ticks: { color: '#9a8a75', font: { family: "'SF Mono', 'Fira Code', monospace", size: 10 }, callback: tickFormat },
            title: { display: true, text: 'Date', color: '#9a8a75', font: { family: "'SF Mono', 'Fira Code', monospace", size: 12 } }
          },
          y: {
            grid: { color: 'rgba(180, 120, 60, 0.08)' },
            ticks: { color: '#9a8a75', font: { family: "'SF Mono', 'Fira Code', monospace", size: 11 } },
            title: { display: true, text: yTitle, color: '#9a8a75', font: { family: "'SF Mono', 'Fira Code', monospace", size: 12 } }
          }
        }
      }
    });
  }

  loadData();
  setInterval(loadData, 300000);
</script>

<style is:global>
  .page {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .bg-glow {
    position: fixed;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
